// Multicycle RISC-V Controller (FSM)
// Harris & Harris, Digital Design and Computer Architecture: RISC-V Edition
//
// States:
//   S0:  Fetch
//   S1:  Decode
//   S2:  MemAdr    (lw/sw address calc)
//   S3:  MemRead   (lw)
//   S4:  MemWB     (lw writeback)
//   S5:  MemWrite  (sw)
//   S6:  ExecuteR  (R-type execute)
//   S7:  ALUWB     (R-type / I-type writeback)
//   S8:  ExecuteI  (I-type ALU execute)
//   S9:  BEQ       (branch execute)
//   S10: JAL       (jump and link)
//
// ALUSrcA: 00=PC, 01=OldPC, 10=A(rs1 register)
// ALUSrcB: 00=B(rs2), 01=ImmExt, 10=4, 11=ImmExt(alias)
// ResultSrc: 00=ALUOut, 01=Data, 10=ALUResult(combinational)

module controller(input  logic        clk, reset,
                  input  logic [6:0]  op,
                  input  logic [2:0]  funct3,
                  input  logic        funct7b5,
                  input  logic        Zero,
                  output logic        PCWrite,
                  output logic        AdrSrc,
                  output logic        MemWrite,
                  output logic        IRWrite,
                  output logic [1:0]  ResultSrc,
                  output logic [2:0]  ALUControl,
                  output logic [1:0]  ALUSrcA,
                  output logic [1:0]  ALUSrcB,
                  output logic [1:0]  ImmSrc,
                  output logic        RegWrite);

  typedef enum logic [3:0] {
    S0  = 4'd0,   // Fetch
    S1  = 4'd1,   // Decode
    S2  = 4'd2,   // MemAdr
    S3  = 4'd3,   // MemRead
    S4  = 4'd4,   // MemWB
    S5  = 4'd5,   // MemWrite
    S6  = 4'd6,   // ExecuteR
    S7  = 4'd7,   // ALUWB
    S8  = 4'd8,   // ExecuteI
    S9  = 4'd9,   // BEQ
    S10 = 4'd10   // JAL
  } statetype;

  statetype state, nextstate;

  logic [1:0] ALUOp;
  logic       Branch, PCUpdate;

  // ALU decoder shared with single-cycle
  aludec ad(op[5], funct3, funct7b5, ALUOp, ALUControl);

  assign PCWrite = PCUpdate | (Branch & Zero);

  // -------------------------------------------------------
  // State Register
  // -------------------------------------------------------
  always_ff @(posedge clk, posedge reset)
    if (reset) state <= S0;
    else       state <= nextstate;

  // -------------------------------------------------------
  // Next State Logic
  // -------------------------------------------------------
  always_comb begin
    case (state)
      S0:  nextstate = S1;
      S1:  case (op)
             7'b0000011: nextstate = S2;   // lw
             7'b0100011: nextstate = S2;   // sw
             7'b0110011: nextstate = S6;   // R-type
             7'b0010011: nextstate = S8;   // I-type ALU
             7'b1100011: nextstate = S9;   // beq
             7'b1101111: nextstate = S10;  // jal
             default:    nextstate = S0;
           endcase
      S2:  nextstate = (op == 7'b0000011) ? S3 : S5;
      S3:  nextstate = S4;
      S4:  nextstate = S0;
      S5:  nextstate = S0;
      S6:  nextstate = S7;
      S7:  nextstate = S0;
      S8:  nextstate = S7;
      S9:  nextstate = S0;
      S10: nextstate = S7;
      default: nextstate = S0;
    endcase
  end

  // -------------------------------------------------------
  // Output Logic
  // -------------------------------------------------------
  always_comb begin
    // Safe defaults
    IRWrite   = 0;
    AdrSrc    = 0;
    ALUSrcA   = 2'b00;
    ALUSrcB   = 2'b00;
    ALUOp     = 2'b00;
    ResultSrc = 2'b00;
    MemWrite  = 0;
    RegWrite  = 0;
    Branch    = 0;
    PCUpdate  = 0;
    ImmSrc    = 2'b00;

    case (state)
      S0: begin // Fetch
        AdrSrc    = 0;
        IRWrite   = 1;
        ALUSrcA   = 2'b00;  // PC
        ALUSrcB   = 2'b10;  // 4
        ALUOp     = 2'b00;
        ResultSrc = 2'b10;  // ALUResult (comb) -> new PC
        PCUpdate  = 1;
      end

      S1: begin // Decode — pre-compute OldPC + ImmExt for branches/jumps
        ALUSrcA   = 2'b01;  // OldPC
        ALUSrcB   = 2'b11;  // ImmExt
        ALUOp     = 2'b00;
        ImmSrc    = 2'b11;  // J-type (branch decode overrides in S9)
      end

      S2: begin // MemAdr — base + offset
        ALUSrcA   = 2'b10;  // A (rs1)
        ALUSrcB   = 2'b01;  // ImmExt
        ALUOp     = 2'b00;
        ImmSrc    = (op == 7'b0100011) ? 2'b01 : 2'b00;
      end

      S3: begin // MemRead
        AdrSrc    = 1;      // Adr = ALUOut
        ResultSrc = 2'b00;
      end

      S4: begin // MemWB
        ResultSrc = 2'b01;  // Data register
        RegWrite  = 1;
        ImmSrc    = 2'b00;
      end

      S5: begin // MemWrite
        AdrSrc    = 1;
        MemWrite  = 1;
        ImmSrc    = 2'b01;  // S-type
      end

      S6: begin // ExecuteR
        ALUSrcA   = 2'b10;  // A
        ALUSrcB   = 2'b00;  // B
        ALUOp     = 2'b10;
      end

      S7: begin // ALUWB
        ResultSrc = 2'b00;  // ALUOut
        RegWrite  = 1;
      end

      S8: begin // ExecuteI
        ALUSrcA   = 2'b10;  // A
        ALUSrcB   = 2'b01;  // ImmExt
        ALUOp     = 2'b10;
        ImmSrc    = 2'b00;  // I-type
      end

      S9: begin // BEQ
        ALUSrcA   = 2'b10;  // A
        ALUSrcB   = 2'b00;  // B
        ALUOp     = 2'b01;  // subtract -> Zero
        ResultSrc = 2'b10;  // branch target (from ALUOut, computed in S1)
        Branch    = 1;
        ImmSrc    = 2'b10;  // B-type
      end

      S10: begin // JAL
        // ALUResult = OldPC + 4 = PCPlus4 -> rd
        // PC        = ALUOut (jump target latched from S1: OldPC + J-imm)
        ALUSrcA   = 2'b01;  // OldPC
        ALUSrcB   = 2'b10;  // 4
        ALUOp     = 2'b00;
        ResultSrc = 2'b10;  // rd <- ALUResult = OldPC+4 = PCPlus4
        PCUpdate  = 1;      // PC <- ALUOut (jump target)
        ImmSrc    = 2'b11;  // J-type
        RegWrite  = 1;
      end

      default: begin end
    endcase
  end

endmodule
