// Multicycle RISC-V Datapath
// Harris & Harris, Digital Design and Computer Architecture: RISC-V Edition
//
// Intermediate registers (new vs single-cycle):
//   OldPC  - holds PC value from Fetch (for branch target calc)
//   Instr  - instruction register (IR)
//   A      - rs1 data register
//   B      - rs2 data register (WriteData output)
//   ALUOut - registered ALU result
//   Data   - registered memory read data
//
// ALUSrcA mux: 00=PC, 01=OldPC, 10=A
// ALUSrcB mux: 00=B,  01=ImmExt, 10=32'd4, 11=ImmExt
// Result  mux: 00=ALUOut, 01=Data, 10=ALUResult(comb)

module datapath(input  logic        clk, reset,
                // from controller
                input  logic [1:0]  ALUSrcA,
                input  logic [1:0]  ALUSrcB,
                input  logic [1:0]  ResultSrc,
                input  logic        AdrSrc,
                input  logic        IRWrite,
                input  logic        PCWrite,
                input  logic        RegWrite,
                input  logic [1:0]  ImmSrc,
                input  logic [2:0]  ALUControl,
                // memory interface
                output logic [31:0] Adr,
                output logic [31:0] WriteData,
                input  logic [31:0] ReadData,
                // to controller
                output logic        Zero,
                // for testbench observation
                output logic [31:0] PC,
                output logic [31:0] Instr);

  // Internal signals
  logic [31:0] OldPC;
  logic [31:0] A, B;
  logic [31:0] ALUResult, ALUOut;
  logic [31:0] Data;
  logic [31:0] ImmExt;
  logic [31:0] SrcA, SrcB;
  logic [31:0] Result;
  logic [31:0] RD1, RD2;

  // -------------------------------------------------------
  // PC register (enabled by PCWrite)
  // -------------------------------------------------------
  flopenr #(32) pcreg(clk, reset, PCWrite, Result, PC);

  // OldPC: captures PC at start of each fetch (for branch/jump target)
  flopr #(32) oldpcreg(clk, reset, PC, OldPC);

  // -------------------------------------------------------
  // Memory address mux
  // -------------------------------------------------------
  mux2 #(32) adrmux(PC, ALUOut, AdrSrc, Adr);

  // -------------------------------------------------------
  // Instruction Register (loaded when IRWrite=1)
  // -------------------------------------------------------
  flopenr #(32) instrreg(clk, reset, IRWrite, ReadData, Instr);

  // -------------------------------------------------------
  // Register File
  // -------------------------------------------------------
  regfile rf(clk, RegWrite,
             Instr[19:15], Instr[24:20], Instr[11:7],
             Result,
             RD1, RD2);

  // A and B: latch register file outputs
  flopr #(32) areg(clk, reset, RD1, A);
  flopr #(32) breg(clk, reset, RD2, B);

  assign WriteData = B;  // for sw instruction

  // -------------------------------------------------------
  // Immediate Extender
  // -------------------------------------------------------
  extend ext(Instr[31:7], ImmSrc, ImmExt);

  // -------------------------------------------------------
  // ALU Source Muxes
  // -------------------------------------------------------
  always_comb
    case (ALUSrcA)
      2'b00:   SrcA = PC;
      2'b01:   SrcA = OldPC;
      2'b10:   SrcA = A;
      default: SrcA = 32'bx;
    endcase

  always_comb
    case (ALUSrcB)
      2'b00:   SrcB = B;
      2'b01:   SrcB = ImmExt;
      2'b10:   SrcB = 32'd4;
      2'b11:   SrcB = ImmExt;
      default: SrcB = 32'bx;
    endcase

  // -------------------------------------------------------
  // ALU
  // -------------------------------------------------------
  alu alu(SrcA, SrcB, ALUControl, ALUResult, Zero);

  // ALUOut register: latches ALUResult each cycle
  flopr #(32) aluoutreg(clk, reset, ALUResult, ALUOut);

  // -------------------------------------------------------
  // Data register: latches ReadData from memory
  // -------------------------------------------------------
  flopr #(32) datareg(clk, reset, ReadData, Data);

  // -------------------------------------------------------
  // Result mux -> feeds PC and register file write
  // -------------------------------------------------------
  always_comb
    case (ResultSrc)
      2'b00:   Result = ALUOut;      // R/I-type result
      2'b01:   Result = Data;        // lw
      2'b10:   Result = ALUResult;   // combinational (PC+4 in fetch, branch target)
      default: Result = 32'bx;
    endcase

endmodule
